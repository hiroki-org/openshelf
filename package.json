{
  "name": "openshelf",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/e2e"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pr:promote": "bash .github/scripts/create-staging-to-main-pr.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint apps/*/src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.7.1",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.6.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    },
    "brace-expansion": "5.0.6",
    "devalue": "^5.6.4",
    "flatted": "^3.4.2",
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "picomatch@^4.0.0": "^4.0.4",
    "next": {
      "postcss": "8.5.12"
    },
    "postcss": "$postcss",
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "vite": "8.0.16",
    "launch-editor": "2.14.1",
    "@babel/core": "7.29.7",
    "ws": "8.21.0",
    "drizzle-kit": {
      "esbuild": "0.28.1"
    },
    "wrangler": {
      "esbuild": "0.28.1"
    }
  },
  "license": "MIT"
}
