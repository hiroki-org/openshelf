{
  "name": "openshelf",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/e2e"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pr:promote": "bash .github/scripts/create-staging-to-main-pr.sh",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint apps/*/src --ext .ts,.tsx"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "axios": "^1.15.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    },
    "devalue": "^5.6.4",
    "flatted": "^3.4.2",
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "picomatch@^4.0.0": "^4.0.4"
  },
  "license": "MIT"
}
