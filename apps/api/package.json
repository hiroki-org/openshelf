{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev --env staging",
    "deploy": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local --env staging",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote --env staging",
    "db:migrate:remote:production": "wrangler d1 migrations apply DB --remote --env production",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260218.0",
    "@codspeed/vitest-plugin": "^5.2.0",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "p-map": "^4.0.0"
  }
}
