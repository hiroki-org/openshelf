{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "vitest/globals", "node"]
  },
  "include": ["src/**/*.ts", "vitest.config.mts"]
}
